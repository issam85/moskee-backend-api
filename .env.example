# Environment Variables voor Moskee Backend API
# Kopieer naar .env voor lokale development
# Voeg toe aan Railway Variables voor productie

# Server Configuration
PORT=3001
NODE_ENV=development
INTERNAL_API_KEY=          # Genereer met: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"

# Supabase Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Frontend URL voor redirects
FRONTEND_URL=https://mijnlvs.nl

# Microsoft 365 - E-mail configuratie
M365_TENANT_ID=your-tenant-id-here
M365_CLIENT_ID=your-client-id-here
M365_CLIENT_SECRET=your-client-secret-here
M365_SENDER_EMAIL=onderwijs@al-hijra.nl

# Email Service Configuration
EMAIL_SERVICE=resend
RESEND_API_KEY=re_xxxxxxxx
RESEND_DOMAIN=mijnlvs.nl

# Stripe Configuratie
STRIPE_SECRET_KEY=sk_test_xxxxxxxx   # Gebruik sk_test_ voor development, sk_live_ alleen op Railway
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
SESSION_LINKING_ENABLED=true
PAYMENT_RETRY_MAX_ATTEMPTS=5
PAYMENT_RETRY_INTERVAL_MINUTES=5

# Security
JWT_SECRET=                # Genereer met: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
